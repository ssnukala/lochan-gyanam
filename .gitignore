# ============================================================================
# lochan-gyanam — workspace bootstrap .gitignore
# ============================================================================
# This repo tracks ONLY docker/, scripts/, repos.json, README.md,
# .gitignore, .dockerignore, .pre-commit-config.yaml (the workspace-level
# infrastructure). Everything else in the gyanam working directory is
# either a separate git repo (ignored here, tracked elsewhere) or
# workspace-local state (data, logs, caches, secrets, ephemera).
# ============================================================================

# ── Child git repos ───────────────────────────────────────────────────────
# Each is its own repo. The deploy script clones them at runtime.
# `mandi/` is workspace-local organization for cloned packages — NOT
# framework substrate. The framework cannot depend on its contents
# (per founder directive 2026-05-22). The mandi catalog is now
# generated INSIDE the mandi package at
# framework/lochan/packages/mandi/backend/data/mandi-catalog.json.
framework/
tools/
mandi/
apps/
domainpkg/
extpackages/

# ── Orphan workspace folders (not part of lochan-gyanam) ─────────────────
# Each of these lives at the gyanam root but isn't this repo's concern.
# See README for where each one belongs (or is planned to belong).
books/            # reference data — astrology, NPI, dictionaries, etc.
patents/          # patent filings (sensitive, immutable filings)
wrap/             # vardhan wrap sessions (v1..vN)
context/          # session context (ephemeral)
names.md          # Sanskrit name registry (lives with framework docs)
.worktrees/       # umbrella for all framework + mandi worktrees (per founder convention 2026-05-14)

# ── Founder-private scripts ──────────────────────────────────────────────
# Private scripts — lives in ssnukala/lochan-util, never on servers.
# Exception: util/scripts/lgit.sh + test-lgit.sh are workspace-canonical
# (founder ratified 2026-05-24; CODING-STANDARDS §7 #7 + [[feedback-no-direct-git-commands-use-lgit-wrapper]]).
util/
!util/
util/*
!util/scripts/
util/scripts/*
!util/scripts/lgit.sh
!util/scripts/test-lgit.sh
!util/scripts/test-util-scripts-strict-mode.sh
!util/scripts/sleep-mode-setup.sh
!util/scripts/wave-runner.sh
!util/scripts/test-capture-run-sidecar-substrate.sh

# ── Secrets — NEVER commit ───────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.sample
!.env.migrated
apps/**/.env
apps/**/.env.*
!apps/**/.env.example
!apps/**/.env.migrated
**/.env.pre-migration-backup

# ── Keys — never commit private keys under any circumstance ──────────────
*.priv
*.pem
*.key
keys/*.ed25519.priv
framework/lochan/keys/*.ed25519.priv
api-project-*.json        # Google API service-account credentials

# ── Host-writable runtime data ───────────────────────────────────────────
apps/*/data/
apps/*/log/
data/
log/
logs/
*.log
*.bak

# ── Daksh / janch runtime reports (generated, not source) ────────────────
.daksh/evolve-log.json
.daksh/cache/
.janch/

# ── Generated frontend assets ─────────────────────────────────────────────
# The mandi catalog moved 2026-05-22 to its canonical location inside
# the mandi package itself:
#   framework/lochan/packages/mandi/backend/data/mandi-catalog.json
# (generated by daksh.generators.mandi_catalog_builder; tracked in the
# lochan repo's .gitignore exception). Frontend reads it via vite alias
# `@/data/mandi-catalog.json`. No catalog file lives in this repo.
framework/lochan/frontend/src/data/mandi-catalog.json

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
build/
dist/

# ── Node / Vite ──────────────────────────────────────────────────────────
node_modules/
.vite/
.next/

# ── IDE / OS droppings ───────────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
._*
*.swp
Thumbs.db

# ── MCP workspace config (machine-specific) ──────────────────────────────
.mcp.json
