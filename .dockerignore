# Docker build context filter — keeps context small when building from gyanam/ root
# Only include what Dockerfiles actually COPY

# Large directories not needed by any Dockerfile
books/
apps/
wrap/
extpackages/
patents/
util/

# Git
.git/
.github/

# Node
**/node_modules/
**/.next/

# Python
**/__pycache__/
**/*.pyc
**/*.egg-info/
**/.venv/
**/.pytest_cache/

# setuptools build artifacts — when a package is pip-installed with
# editable + pep517 backends, setuptools writes a stale tree at
# ``<pkg>/backend/build/lib/<pkg>/``. If this gets copied into the Docker
# build context, setuptools picks it up over the fresh source and the
# resulting wheel contains the OLD code. Surface example (post-stable
# fwprod01 build 2026-06-10): daksh.secrets.models retained the retired
# ``from trishul.sepoy.models.base import Base`` import even though
# disk source had been migrated to ``from muulam.data import Base`` —
# setuptools resolved against ``daksh/backend/build/lib/daksh/secrets/
# models.py`` (the stale tree) instead of the canonical
# ``daksh/backend/daksh/secrets/models.py``. The build/ tree IS in
# .gitignore but was not in .dockerignore — so it landed in the build
# context. Excluding it here forces pip to install from the canonical
# source tree only.
**/backend/build/
**/build/lib/

# IDE / OS
.vscode/
.idea/
**/.DS_Store

# Logs and runtime data
**/log/
# NOTE: framework/lochan/data/ is intentionally NOT excluded — it holds the
# patent-coverage-status.json claim matrix (Sweep A10 / FP11 60s demo) that
# muulam.api.patent_coverage reads at runtime. The .json files here are
# STATIC manifests (checked into git), not runtime DB/log artifacts.

# Build artifacts (these are what we're eliminating)
framework/lochan/.build/
framework/lochan/.build-staging/
framework/lochan/.daksh/
framework/lochan/.forge-tmp/

# Test artifacts
**/htmlcov/
**/.coverage

# Secrets — defense-in-depth. No current Dockerfile uses `COPY . .`, but
# operators who fork the templates MUST NOT bake these into an image.
# Anything that matches these globs will be excluded from every build
# context rooted at gyanam/. (Release-safe allow-list: .env.example and
# .env.migrated are placeholders and may be included.)
**/.env
**/.env.*
!**/.env.example
!**/.env.migrated

# Private keys — never put a signing / encryption key into a layer.
**/keys/*.priv
**/*.priv
**/*.pem
framework/lochan/keys/publisher.ed25519.priv

# Encrypted backups — produced by util/scripts/backup-encrypted.sh.
# They don't belong in an image even though they're already encrypted —
# keeps image size small.
**/backups/
**/*.age
**/*.gpg
