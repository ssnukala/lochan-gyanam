{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lochan.dev/schemas/mandi.json",
  "title": "Mandi Package Manifest",
  "description": "Root identity manifest for Lochan marketplace packages. Contains only marketplace identity and branding — backend, frontend, locale, chat, and AI config live in separate files.",
  "type": "object",
  "required": ["name", "version", "description"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Package identifier (lowercase, hyphenated)",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "description": "Semver version",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$"
    },
    "label": {
      "type": "string",
      "description": "Human-readable label"
    },
    "description": {
      "type": "string",
      "description": "Short description (one line)"
    },
    "sanskrit": {
      "type": "string",
      "description": "Sanskrit script name"
    },
    "meaning": {
      "type": "string",
      "description": "Meaning of the Sanskrit name"
    },
    "chaldean": {
      "type": "integer",
      "description": "Chaldean numerology value"
    },
    "author": {
      "type": "string",
      "description": "Package author or organization"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier or 'proprietary'"
    },
    "repo": {
      "type": "string",
      "description": "Git repository URL (short form)"
    },
    "repository": {
      "type": "string",
      "description": "Git repository URL (alias for repo)"
    },
    "category": {
      "type": "string",
      "enum": ["intelligence", "communication", "data", "extension", "language", "credential", "wellbeing", "integration", "analytics", "workflow"],
      "description": "Package category"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Search discovery tags"
    },
    "icon": {
      "type": "string",
      "description": "MUI icon name for display"
    },
    "requires": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Required core/mandi packages"
    },
    "optional": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional packages that enhance this one"
    },
    "provides": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Capabilities this package provides"
    },
    "app": {
      "type": "object",
      "description": "App branding overrides (for primary packages)",
      "properties": {
        "name": { "type": "string" },
        "tagline": { "type": "string" },
        "logo_icon": { "type": "string" },
        "logo_color": { "type": "string" }
      }
    },
    "sub_packages": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Sub-package module names (for multi-package domains)"
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "lochan_min": { "type": "string" },
        "python_min": { "type": "string" },
        "postgres_features": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "tier": {
      "type": "string",
      "enum": ["core", "framework", "domain"],
      "description": "Distribution tier: core (base image), framework (optional, mandi array), domain (app-specific)",
      "default": "framework"
    },
    "trust_level": {
      "type": "string",
      "enum": ["core", "verified", "community", "unverified"],
      "default": "verified"
    }
  },
  "additionalProperties": false
}
